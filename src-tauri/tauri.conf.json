{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FORLAS CRQ",
  "version": "0.1.0",
  "identifier": "app.forlas.crq",
    "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "FORLAS CRQ",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765 http://localhost:8765 ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "copyright": "Copyright © 2026 Michael Walker · MIT License",
    "shortDescription": "Local-first quantitative cyber risk platform",
    "longDescription": "FORLAS CRQ — local-first quantitative cyber risk platform. Monte Carlo simulation, FAIR decomposition, portfolio aggregation, governance and reporting. Offline. No telemetry.",
    "externalBin": [
      "binaries/forlas-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
